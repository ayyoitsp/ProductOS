{
  "openapi": "3.0.0",
  "info": {
    "title": "Family Wallet API",
    "version": "0.1.0",
    "description": "Backend for the Family Wallet demo app. Single-source-of-truth ledger for kids, tasks, transactions, and interest config."
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "schemas": {
      "Kid": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "example": "#f97316"
          },
          "avatar": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "color",
          "avatar",
          "created_at"
        ]
      },
      "Balances": {
        "type": "object",
        "additionalProperties": {
          "type": "integer"
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "CreateKidInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "color": {
            "type": "string"
          },
          "avatar": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "name",
          "color"
        ]
      },
      "UpdateKidInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "color": {
            "type": "string"
          },
          "avatar": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TxType": {
        "type": "string",
        "enum": [
          "task",
          "interest",
          "earn",
          "spend",
          "adjustment"
        ]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "kid_id": {
            "type": "integer"
          },
          "amount_cents": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/TxType"
          },
          "related_task_id": {
            "type": "integer",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "kid_id",
          "amount_cents",
          "reason",
          "type",
          "related_task_id",
          "created_at"
        ]
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "amount_cents": {
            "type": "integer"
          },
          "recurring": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "active": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "amount_cents",
          "recurring",
          "active",
          "created_at"
        ]
      },
      "CreateTaskInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "recurring": {
            "type": "boolean",
            "default": true
          }
        },
        "required": [
          "name",
          "amount_cents"
        ]
      },
      "UpdateTaskInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "recurring": {
            "type": "boolean"
          }
        }
      },
      "CompleteTaskInput": {
        "type": "object",
        "properties": {
          "kid_id": {
            "type": "integer"
          },
          "amount_cents": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "comment": {
            "type": "string"
          }
        },
        "required": [
          "kid_id"
        ]
      },
      "CreateTransactionInput": {
        "type": "object",
        "properties": {
          "kid_id": {
            "type": "integer"
          },
          "amount_cents": {
            "type": "integer"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "$ref": "#/components/schemas/TxType"
          }
        },
        "required": [
          "kid_id",
          "amount_cents",
          "reason",
          "type"
        ]
      },
      "InterestConfig": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "rate_pct": {
            "type": "number"
          },
          "days": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6
            }
          },
          "last_applied": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "enabled",
          "rate_pct",
          "days",
          "last_applied"
        ]
      },
      "UpdateInterestConfigInput": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "rate_pct": {
            "type": "number"
          },
          "days": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0,
              "maximum": 6
            }
          },
          "last_applied": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ApplyResult": {
        "type": "object",
        "properties": {
          "applied": {
            "type": "boolean"
          },
          "credited": {
            "type": "integer"
          }
        },
        "required": [
          "applied",
          "credited"
        ]
      },
      "ApplyNowResult": {
        "type": "object",
        "properties": {
          "credited": {
            "type": "integer"
          }
        },
        "required": [
          "credited"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/kids": {
      "get": {
        "tags": [
          "kids"
        ],
        "responses": {
          "200": {
            "description": "List of kids",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Kid"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "kids"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKidInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Kid"
                }
              }
            }
          }
        }
      }
    },
    "/kids/balances": {
      "get": {
        "tags": [
          "kids"
        ],
        "responses": {
          "200": {
            "description": "Map of kid id to balance in cents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Balances"
                }
              }
            }
          }
        }
      }
    },
    "/kids/{id}": {
      "get": {
        "tags": [
          "kids"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Kid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Kid"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "kids"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateKidInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Kid"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "kids"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    },
    "/kids/{id}/transactions": {
      "get": {
        "tags": [
          "kids"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "maximum": 500,
              "default": 100
            },
            "required": false,
            "name": "limit",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions for kid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transaction"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/kids/{id}/balance": {
      "get": {
        "tags": [
          "kids"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Balance in cents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cents": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "cents"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/tasks": {
      "get": {
        "tags": [
          "tasks"
        ],
        "responses": {
          "200": {
            "description": "Active tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{id}": {
      "patch": {
        "tags": [
          "tasks"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "tasks"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          }
        }
      }
    },
    "/tasks/{id}/complete": {
      "post": {
        "tags": [
          "tasks"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteTaskInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resulting transaction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/transactions": {
      "post": {
        "tags": [
          "transactions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTransactionInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Transaction"
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{id}": {
      "delete": {
        "tags": [
          "transactions"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/settings/interest": {
      "get": {
        "tags": [
          "settings"
        ],
        "responses": {
          "200": {
            "description": "Interest config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterestConfig"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateInterestConfigInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated interest config",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterestConfig"
                }
              }
            }
          }
        }
      }
    },
    "/interest/apply-if-due": {
      "post": {
        "tags": [
          "interest"
        ],
        "responses": {
          "200": {
            "description": "Result of conditional apply",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplyResult"
                }
              }
            }
          }
        }
      }
    },
    "/interest/apply-now": {
      "post": {
        "tags": [
          "interest"
        ],
        "responses": {
          "200": {
            "description": "Result of unconditional apply",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplyNowResult"
                }
              }
            }
          }
        }
      }
    }
  }
}